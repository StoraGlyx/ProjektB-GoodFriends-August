@page
@model FriendDetailsModel

@if (Model.Friend != null)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1>@Model.Friend.FirstName @Model.Friend.LastName</h1>
            <p class="text-muted mb-0">Friend details</p>
        </div>

        <div>
            <a class="btn btn-secondary" asp-page="/Friends">Back</a>
            <a class="btn btn-warning" asp-page="/EditFriend" asp-route-id="@Model.Friend.FriendId">
                Edit Friend
            </a>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">
            Friend
        </div>
        <div class="card-body">
            <p><strong>Name:</strong> @Model.Friend.FirstName @Model.Friend.LastName</p>
            <p><strong>Birthday:</strong> @Model.Friend.Birthday</p>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Address</span>

            <a class="btn btn-warning btn-sm" asp-page="/EditAddress" asp-route-friendId="@Model.Friend.FriendId">
                Edit Address
            </a>
        </div>

        <div class="card-body">
            <p><strong>Street:</strong> @Model.Friend.Address?.StreetAddress</p>
            <p><strong>Zip:</strong> @Model.Friend.Address?.ZipCode</p>
            <p><strong>City:</strong> @Model.Friend.Address?.City</p>
            <p><strong>Country:</strong> @Model.Friend.Address?.Country</p>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">
            Pets
        </div>
        <div class="card-body">
            @if (Model.Friend.Pets != null && Model.Friend.Pets.Any())
            {
                <ul class="mb-0">
                    @foreach (var pet in Model.Friend.Pets)
                    {
                        <li>@pet.Name</li>
                    }
                </ul>
            }
            else
            {
                <p class="mb-0">No pets.</p>
            }
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">
            Quotes
        </div>
        <div class="card-body">
            @if (Model.Friend.Quotes != null && Model.Friend.Quotes.Any())
            {
                <ul class="mb-0">
                    @foreach (var quote in Model.Friend.Quotes)
                    {
                        <li>@quote.QuoteText</li>
                    }
                </ul>
            }
            else
            {
                <p class="mb-0">No quotes.</p>
            }
        </div>
    </div>
}
else
{
    <div class="alert alert-warning">
        Friend could not be found.
    </div>
}